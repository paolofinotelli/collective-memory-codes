%%% GENERALIZATION TO LARGER MATRICES %%%

%% Parameters
n = 1e5;       % number of subjects
m = 20;        % number of questions
density_B = 5/n;  % density for sparse B
theta = 0.6;      % weighting parameter
T = 100;          % max iterations
tol = 1e-6;       % convergence tolerance
sigma_values = [0, 0.01, 0.05, 0.1, 0.3, 0.5];  % noise levels

%% 1. Build sparse stochastic B matrix
A = sprand(n, n, density_B);          % sparse random adjacency
row_sums = sum(A, 2);
A = spdiags(1 ./ full(row_sums), 0, n, n) * A;  % normalize rows
I = speye(n);
B = theta * A + (1-theta) * I;        % ensures spectral radius <= 1

%% 2. Generate initial sparse memory matrix M0
density_M0 = 0.1;  % 10% nonzero entries
S = sprand(n, m, density_M0);  
[i,j] = find(S);
values = 10 * rand(length(i), 1);  % Uniform [0,10]
M0 = sparse(i, j, values, n, m);

%% 3. Standardize columns
mean_M0 = mean(M0, 1);           % 1x20 column means  
std_M0 = std(M0, 0, 1);          % 1x20 column stds
M0_std = (M0 - mean_M0) ./ std_M0;

%% 4. Iterate for each sigma value
num_sigmas = length(sigma_values);
M_star_all = cell(num_sigmas,1);

for s = 1:num_sigmas
    sigma = sigma_values(s);
    Mt = M0_std;
    
    for t = 1:T
        epsilon = sigma * randn(size(Mt));  % Gaussian noise
        Mt_next = B * Mt + epsilon;         % update memory with noise
        if norm(Mt_next - Mt, 'fro') < tol
            break;
        end
        Mt = Mt_next;
    end
    
    % Store final matrix in original score scale
    M_star_all{s} = Mt .* std_M0 + mean_M0;
    fprintf('Sigma = %.2f, iterations = %d\n', sigma, t);
end

%% 5. Visualize results (first 2000 subjects)
figure('Position', [100 100 1500 600]);

for s = 1:num_sigmas
    % Heatmap
    subplot(2, num_sigmas, s);
    imagesc(M_star_all{s}(1:2000, :));
    colormap(parula); colorbar;
    title(sprintf('M^* (\\sigma=%.2f)', sigma_values(s)));
    xlabel('Questions'); ylabel('Subjects');
    
    % Column stds
    subplot(2, num_sigmas, s+num_sigmas);
    col_stds = full(std(M_star_all{s}, 0, 1));
    bar(col_stds); 
    title(sprintf('Column std (\\sigma=%.2f)', sigma_values(s)));
    ylabel('Std dev'); xlabel('Questions');
    yline(mean(col_stds), 'r--', 'Mean std');
end

sgtitle('Effect of noise on convergence of large sparse memory matrix');

